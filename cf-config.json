          },
          "MinTTL": 0,
          "DefaultTTL": 0,
          "MaxTTL": 0,
          "ForwardedValues": {
            "QueryString": true,
            "Cookies": {
              "Forward": "all"
            },
            "Headers": {
              "Quantity": 1,
              "Items": [
                "*"
              ]
            }
          }
        }
      ]
    },
    "CustomErrorResponses": {
      "Quantity": 1,
      "Items": [
        {
          "ErrorCode": 404,
          "ResponsePagePath": "/index.html",
