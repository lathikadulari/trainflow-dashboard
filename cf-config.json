{
  "DistributionConfig": {
    "CallerReference": "trainflow-deploy-1774448738730",
    "Comment": "TrainFlow Dashboard Frontend and API Routing",
    "Enabled": true,
    "DefaultRootObject": "index.html",
    "Origins": {
      "Quantity": 2,
      "Items": [
        {
          "Id": "S3Origin",
          "DomainName": "trainflow-frontend-1774448709412.s3.ap-south-1.amazonaws.com",
          "S3OriginConfig": {
            "OriginAccessIdentity": ""
          },
          "OriginAccessControlId": "E1QJ1W5WVDZZ2Y"
        },
        {
          "Id": "EC2Origin",
          "DomainName": "13.233.186.145",
          "CustomOriginConfig": {
            "HTTPPort": 80,
            "HTTPSPort": 443,
            "OriginProtocolPolicy": "http-only",
            "OriginSslProtocols": {
              "Quantity": 1,
              "Items": [
                "TLSv1.2"
              ]
            }
          }
        }
      ]
    },
    "DefaultCacheBehavior": {
